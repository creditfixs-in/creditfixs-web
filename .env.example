# Copy to .env.local for local dev (`next dev`). Real values NEVER go in this file.
# Production: SUPABASE_URL is set in wrangler.jsonc "vars" (deployed automatically);
# SUPABASE_SERVICE_ROLE_KEY is a Worker secret — set once with:
#   npx wrangler secret put SUPABASE_SERVICE_ROLE_KEY
# Secrets persist across deploys, so no per-deploy action is needed.

# Supabase project URL — origin only, no /rest/v1/ suffix (the code adds it).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service-role key (Settings -> API -> service_role). Server-side only — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
